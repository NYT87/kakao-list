# PWA
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key
VITE_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key
# Must match the Kakao Developers web redirect URI for the deployed PWA.
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
VITE_KAKAO_SCOPE=
VITE_PWA_BASE_URL=http://localhost:5173
# Must point to the deployed sync API base URL and include http:// or https://.
VITE_SYNC_SERVER_URL=http://localhost:8787
VITE_ENABLE_MOCK_AUTH=false
DEBUG_MODE=false

# Extension
# Must point to the deployed sync API base URL and include http:// or https://.
# For the extension build, VITE_SYNC_SERVER_URL is also injected into manifest host_permissions.
VITE_SYNC_SERVER_URL=http://localhost:8787
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key
VITE_KAKAO_SCOPE=
VITE_PWA_BASE_URL=http://localhost:5173
VITE_ENABLE_MOCK_AUTH=false
DEBUG_MODE=false
EXTENSION_PUBLIC_KEY=

# Server
PORT=8787
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kakao_lists
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
SYNC_SERVER_SIGNING_SECRET=replace_with_a_long_random_secret
ALLOW_MOCK_AUTH=false
